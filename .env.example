# Magisor Environment Variables Template
# Copy this file to '.env' and fill in any secrets needed.
# Note: The Gemini Vision API key is user-supplied via the app settings
# and is stored in 'settings.json'. You do NOT need to set it here.

# Any other service API keys or system environment variables can go here:
MAGISOR_ENV=development
LOG_LEVEL=INFO
GEMINI_MODEL=gemini-2.0-flash
GEMINI_API_KEY=
